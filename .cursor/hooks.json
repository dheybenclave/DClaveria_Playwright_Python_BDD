{
  "hooks": {
    "sessionStart": [
      {
        "command": "python .cursor/hooks/session_start.py",
        "event": "sessionStart",
        "description": "Show QA agentic startup checklist"
      }
    ],
    "beforeShellExecution": [
      {
        "command": "python .cursor/hooks/before_shell_execution.py",
        "event": "beforeShellExecution",
        "description": "Block unsafe git commands in automation workflow"
      }
    ],
    "afterShellExecution": [
      {
        "command": "python .cursor/hooks/after_shell_execution.py",
        "event": "afterShellExecution",
        "description": "Remind quick verification commands after shell actions"
      }
    ],
    "afterFileEdit": [
      {
        "command": "python .cursor/hooks/after_file_edit.py",
        "event": "afterFileEdit",
        "description": "Remind collection smoke and targeted marker runs"
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "python .cursor/hooks/before_submit_prompt.py",
        "event": "beforeSubmitPrompt",
        "description": "Warn about common secret token patterns"
      }
    ]
  }
}
