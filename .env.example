# Playwright BDD Framework — Environment Configuration
# Copy this file to .env and fill in real values.
# IMPORTANT: .env is git-ignored. Never commit real secrets.

# ============================================
# Required
# ============================================
BASE_URL=https://automationexercise.com

# ============================================
# Browser Runtime
# ============================================
HEADLESS=true
RECORD_VIDEO=false
PLAYWRIGHT_DEFAULT_TIMEOUT=15000

# ============================================
# Test Accounts (optional – for multi-user scenarios)
# ============================================
ADMIN_EMAIL=admin@test.com
ADMIN_PASSWORD=admin_password_here
USER_EMAIL=user@test.com
USER_PASSWORD=user_password_here

# ============================================
# Bulk Credentials (JSON array – for data-driven scenarios)
# Pass as a single-line JSON string.
# Example:
# LIST_OF_CREDENTIALS='[{"email":"user1@test.com","password":"pass1"},{"email":"user2@test.com","password":"pass2"}]'
# ============================================
LIST_OF_CREDENTIALS=

# ============================================
# Reporting
# ============================================
AUTO_GENERATE_ALLURE=false
AUTO_OPEN_ALLURE=false

# ============================================
# CI/CD Overrides (set in Jenkins env, not in .env)
# These are typically configured as Jenkins credentials or global env vars
# Jenkins will override these if set in the pipeline environment block.
# ============================================
# LIST_OF_CREDENTIALS (Jenkins secret text)
# ADMIN_EMAIL (Jenkins secret text)
# ADMIN_PASSWORD (Jenkins secret text)
