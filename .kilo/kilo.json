{
  "$schema": "https://app.kilo.ai/config.json",
  "model": "kilo/minimax/minimax-m2.1:free",
  "permission": {
    "bash": "allow"
  },
  "description": "Playwright Python BDD Test Automation Project",
  "alwaysApply": true,
  "commands": {
    "test": "Run pytest tests",
    "verify": "Verify environment setup",
    "collect": "Collect test cases",
    "debug": "Debug failing tests"
  },
  "agents": {
    "test-planner": "Playwright test planning agent",
    "test-healer": "Self-heal failing tests",
    "test-generator": "Generate test cases"
  }
}
